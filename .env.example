# Supabase (required for auth and data)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase CLI (supabase link, db push) - project ref = subdomain of your URL
# SUPABASE_PROJECT_ID=your-project-ref
# SUPABASE_DB_PASSWORD=your-database-password

# Mapbox (required for geographic map; falls back to SVG map if missing)
NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-token

# PRD mode: when true, hides admin/moderation, disables map test panel, Etéreo popup defaults; sidebar shows only Filtros, Capas y Registros (no Escenografía ni Prueba mapa)
NEXT_PUBLIC_PRD=false

# Radio FM exploration: when false, hide "Explorar con radio" UI entirely
NEXT_PUBLIC_RADIO_EXPLORATION=true

# Auth propio (sesión y admin)
AUTH_SECRET=minimo-32-caracteres-para-firmar-cookies

# Admin y subida de landmarks (obligatorio si usas /admin)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
